{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "catppuccin",
  "keybinds": {
    // https://opencode.ai/docs/keybinds
    "agent_cycle": "tab",
    "agent_list": "<leader>a",
    "app_exit": "ctrl+q",
    "editor_open": "ctrl+e",
    "input_clear": "ctrl+c",
    "input_newline": "shift+enter,ctrl+j",
    "input_paste": "ctrl+v",
    "input_submit": "enter",
    "leader": "ctrl+space",
    "messages_first": "ctrl+g",
    "messages_last": "ctrl+shift+g",
    "messages_page_down": "pagedown,ctrl+d",
    "messages_page_up": "pageup,ctrl+u",
    "model_list": "<leader>m",
    "session_child_cycle": "<leader>right",
    "session_child_cycle_reverse": "<leader>left",
    "session_compact": "<leader>c", // Cannot be used with GitHub Copilot
    "session_interrupt": "esc",
    "session_list": "<leader>l",
    "session_parent": "<leader>up",
    "session_timeline": "<leader>t",
    "sidebar_toggle": "ctrl+s",
    "status_view": "<leader>s",
  },
  "diff_style": "auto",
}
