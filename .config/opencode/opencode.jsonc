{
  "$schema": "https://opencode.ai/config.json",
  // https://github.blog/changelog/2026-01-16-github-copilot-now-supports-opencode/
  "model": "github-copilot/claude-opus-4.6",
  "permission": {
    "read": "allow",
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      // Unless specified otherwise, ask for permission.
      // (Since the last matching rule takes precedence, put the * wildcard first and specific rules after.)
      "*": "ask",
      // Allow read-only commands
      "pwd": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "echo *": "allow",
      // Git read-only commands
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "git remote -v": "allow",
    },
    "task": "ask",
    "skill": "ask",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "allow",
    "external_directory": "ask",
    "doom_loop": "ask",
  },

  // Agents are defined in ~/.config/opencode/agent/*.md
  "agent": {
    "build": {
      "disable": true,
    },
    "plan": {
      "disable": true,
    },
  },

  "formatter": {
    "ruff-format": {
      "extensions": [".py"],
      "command": ["ruff", "format", "$FILE"],
    },
    "ruff-fix": {
      "extensions": [".py"],
      "command": ["ruff", "check", "--fix", "$FILE"],
    },
    "rustfmt": {
      "extensions": [".rs"],
      "command": ["rustfmt", "$FILE"],
    },
  },

  // If true, OpenCode will automatically download any new updates when it starts up.
  "autoupdate": false,
}
